# VolGuard Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore

# ── Upstox Credentials (required) ─────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=your_daily_upstox_token_here
UPSTOX_CLIENT_ID=your_upstox_client_id
UPSTOX_CLIENT_SECRET=your_upstox_client_secret

# ── Webhook Security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=

# ── Telegram Alerts (optional but strongly recommended) ───────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Intelligence Layer (optional — system works without) ───────────────────
# Priority: ANTHROPIC_API_KEY (Claude — primary, best quality) → GROQ_API_KEY (free fallback)
# Right now the system runs on Groq (free tier) — add ANTHROPIC_API_KEY to upgrade silently.
# IMPORTANT: Claude also unlocks web_search on morning brief (real-time market causality).
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── Macro Data Sources (replaces yfinance — blocked on AWS) ───────────────────
# Twelve Data: global equities, FX, commodities. Free tier: 800 calls/day.
# Get free key at: https://twelvedata.com (no credit card needed)
TWELVE_DATA_API_KEY=

# FRED (Federal Reserve): US 10Y Treasury yield. Completely free.
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to true to inject a realistic mock NIFTY Iron Condor into the Live Desk.
# Every mock response is clearly labelled in the UI — nothing is hidden.
# Switch to false (or remove) when deploying with real capital.
DEMO_MODE=true

# ── Database (do not change — set by docker-compose) ─────────────────────────
DATABASE_URL=sqlite:////app/data/volguard.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=/app/logs/volguard.log

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Timezone (critical for IST-based market timing) ──────────────────────────
TZ=Asia/Kolkata
